            "exec": [
              "var jsonData = pm.response.json();",
              "if (jsonData.access) {",
              "    pm.collectionVariables.set(\"accessToken\", jsonData.access);",
              "    pm.test(\"Token stored successfully\", function () {",
              "        pm.expect(jsonData.access).to.be.a('string');",
              "    });",
              "}"
            ],
